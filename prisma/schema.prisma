// =============================================================================
// VEXCO-SPACE DATABASE SCHEMA
// Strategic Intelligence Engine with INVEST Validation System
// =============================================================================
// QA AUDIT NOTES:
// - ProjectStatus enum: Traffic light system for concept validation stages
// - ConceptInsight: Stores Q&A pairs from Gemini INVEST analysis
// - Project relations: conceptInsights for validation tracking
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// USER & AUTHENTICATION MODELS
// QA: Standard NextAuth.js integration with Google SSO
// =============================================================================

model User {
  id               String            @id @default(cuid())
  name             String?
  email            String            @unique
  emailVerified    DateTime?
  password         String?
  image            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  accounts         Account[]
  sessions         Session[]
  projects         Project[]
  ideas            Idea[]
  notes            Note[]
  links            Link[]
  images           Image[]
  chatMessages     ChatMessage[]
  // V4 relations
  agileTasks       AgileTask[]
  inboxItems       InboxItem[]
  knowledgeBase    KnowledgeBase[]
  roadmapTimelines RoadmapTimeline[]
  automationLogs   AutomationLog[]
  userPreferences  UserPreferences?
  decisionLogs     DecisionLog[]
  warRoomSessions  WarRoomSession[]
  firmInsights     FirmInsight[]
  // Sprint M — Cross-portfolio
  channels     Channel[]
  prospects    Prospect[]
  metaProjects MetaProject[]
  // Sprint Inbox Intelligence — few-shot calibration
  inboxCorrections InboxCorrection[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// =============================================================================
// STRATEGIC INTELLIGENCE ENGINE - PROJECT STATUS ENUM
// QA: Traffic light system for validation stages
// - RED: Not validated, requires attention
// - YELLOW: In progress, pending validation
// - GREEN: Validated, ready to proceed
// =============================================================================

enum ProjectStatus {
  RED
  YELLOW
  GREEN
}

// =============================================================================
// STRATEGIC INTELLIGENCE ENGINE - CONCEPT INSIGHT MODEL
// QA: Stores INVEST validation Q&A pairs from Gemini analysis
// - question: Gemini-generated question based on INVEST gaps
// - answer: User's response to the question
// - stage: Which validation stage (Concepto, Mercado, Negocio, Ejecución)
// =============================================================================

model ConceptInsight {
  id                  String   @id @default(cuid())
  projectId           String
  question            String   @db.Text
  answer              String?  @db.Text
  stage               String // Concepto, Mercado, Negocio, Ejecución
  // Strategic PM Lab - Enhanced fields
  userFeedback        String?  @db.Text // User refinement request ("ajusta X")
  aiSuggestion        String?  @db.Text // AI's suggestion/draft
  alternatives        String?  @db.Text // JSON array of alternative paths
  analysisType        String? // consultation, validation, refinement, cascade
  costBenefitAnalysis String?  @db.Text // Cost/benefit analysis text
  killSwitchReason    String?  @db.Text // Reason if kill switch issued
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  project             Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([stage])
  @@index([analysisType])
}

// =============================================================================
// CORE PROJECT MODEL
// QA: Enhanced with Strategic Intelligence Engine fields
// - startDate/endDate: Agile sprint tracking (red highlight if overdue)
// - conceptStatus: Traffic light for Concepto stage
// - marketStatus: Traffic light for Mercado stage
// - businessStatus: Traffic light for Negocio stage
// - executionStatus: Traffic light for Ejecución stage
// =============================================================================

model Project {
  id          String    @id @default(cuid())
  title       String
  description String?   @db.Text
  status      String    @default("idea") // idea, development, execution, completed
  projectType String    @default("idea") // idea, active, operational, completed
  category    String?
  // Sprint Convergencia v2 — NAICS 2-digit sectoral classification
  naicsSector            String?   // 2-digit NAICS code: "11", "21", "22", "23", "31", "42", "44", "48", "51", "52", "53", "54", "55", "56", "61", "62", "71", "72", "81", "92"
  naicsSectorConfidence  Float?    // 0.0-1.0, populated by auto-classifier
  naicsSectorReviewed    Boolean   @default(false)
  naicsSectorReasoning   String?   @db.Text  // Razonamiento del classifier (incluye prefix de subject: [EXTERNAL_CLIENT], [VEXCO_OPERATING], [HORIZONTAL_OFFER], [METHODOLOGICAL])
  tags        String[]  @default([])
  priority    String    @default("medium") // low, medium, high
  progress    Int       @default(0) // 0-100
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Strategic Intelligence Engine - Timeline
  // QA: startDate/endDate for agile metrics, red if currentDate > endDate
  startDate DateTime?
  endDate   DateTime?

  // Strategic Intelligence Engine - 4-Stage Traffic Light System
  // QA: Each stage must be GREEN before proceeding to next
  conceptStatus   ProjectStatus @default(RED) // Stage 1: Concepto
  marketStatus    ProjectStatus @default(RED) // Stage 2: Mercado
  businessStatus  ProjectStatus @default(RED) // Stage 3: Negocio
  executionStatus ProjectStatus @default(RED) // Stage 4: Ejecución

  // Framework fields (legacy)
  concept          String? @db.Text // Step 1
  problemSolved    String? @db.Text
  targetMarket     String? @db.Text // Step 2
  marketValidation String? @db.Text
  businessModel    String? @db.Text // Step 3
  valueProposition String? @db.Text
  actionPlan       String? @db.Text // Step 4
  milestones       String? @db.Text
  resources        String? @db.Text // Step 5
  metrics          String? @db.Text
  currentStep      Int     @default(1) // 1-5

  // V4 relations
  trackType     TrackType        @default(GO_TO_MARKET)
  archetype     ProjectArchetype @default(CLIENT)
  isArchived    Boolean          @default(false)
  driveFolderId String?          // Google Drive folder ID linked to this project

  // Revenue Priority System
  revenueProximityScore   Int?      // 1-10, evaluated by Strategist (10 = ready to invoice)
  revenueProximityReason  String?   @db.Text // Why this score — Strategist's judgment
  stepsToRevenue          Int?      // Estimated steps to first invoice
  stepsToRevenueDetail    String?   @db.Text // Description of each step
  estimatedRevenueDate    DateTime? // When could first revenue happen
  revenueLastAssessedAt   DateTime? // Last time Strategist evaluated this
  revenueLastAssessedBy   String?   // Agent ID that last assessed

  // Relations
  ideas            Idea[]
  notes            Note[]
  links            Link[]
  images           Image[]
  milestoneItems   Milestone[]
  patternCards     PatternCard[]
  conceptInsights  ConceptInsight[] // Strategic Intelligence Engine Q&A
  agileTasks       AgileTask[]
  inboxItems       InboxItem[]
  roadmapTimelines RoadmapTimeline[]
  decisionLogs     DecisionLog[]
  warRoomSessions   WarRoomSession[]
  chatMessages      ChatMessage[]
  driveDocSummaries DriveDocSummary[]
  documents         DocumentGeneration[]
  firmInsights      FirmInsight[] @relation("InsightSource")
  // Sprint M — Cross-portfolio
  channelLinks          ChannelProject[]
  prospectFits          ProspectFit[]
  metaProjectComponents MetaProjectComponent[]
  // Sprint M.2a-PLUS — Frameworks
  frameworks            FrameworkProject[]
  // Sprint Upload-A — Local files
  files                 ProjectFile[]

  @@index([userId])
  @@index([status])
  @@index([projectType])
  @@index([conceptStatus])
  @@index([trackType])
  @@index([naicsSector])
}

// =============================================================================
// SPRINT UPLOAD-A — PROJECT FILES (local uploads, storage + visibility)
// QA: S3-backed user uploads per project. No Stage A/B processing.
// =============================================================================

model ProjectFile {
  id         String   @id @default(cuid())
  projectId  String
  fileName   String
  fileKey    String   @unique
  fileSize   Int
  mimeType   String
  uploadedAt DateTime @default(now())

  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([uploadedAt])
}

// =============================================================================
// GLOBAL DESIGN ENGINE - PATTERN SYSTEM
// QA: Extracts UX/UI patterns from Drive folders
// =============================================================================

enum PatternCategory {
  VISUAL_PATTERN
  TOOL_IMPLEMENTATION
}

model PatternCard {
  id                  String          @id @default(cuid())
  name                String
  description         String          @db.Text
  category            PatternCategory
  howToApply          String          @db.Text
  cssCode             String?         @db.Text
  installationCommand String?
  docsUrl             String?
  sourceUrl           String?
  projectId           String?
  project             Project?        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([projectId])
  @@index([category])
}

// =============================================================================
// SUPPORTING MODELS
// =============================================================================

// =============================================================================
// MILESTONE MODEL - AI-CERTIFIED ACHIEVEMENT TRACKING
// QA: Milestones are auto-generated and AI-certified (not manually marked)
// - certifiedAt: Timestamp when AI audited and certified completion
// - certificationReason: AI's explanation for certification
// - projectType: SaaS, Product, Service - influences milestone templates
// =============================================================================

model Milestone {
  id                  String    @id @default(cuid())
  title               String
  description         String?   @db.Text
  projectType         String? // SaaS, Product, Service
  isCompleted         Boolean   @default(false)
  isCertified         Boolean   @default(false)
  certifiedAt         DateTime?
  certificationReason String?   @db.Text
  order               Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  projectId           String
  project             Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([isCertified])
}

model Idea {
  id         String   @id @default(cuid())
  title      String
  content    String   @db.Text
  category   String?
  tags       String[] @default([])
  isFavorite Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId  String?
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
}

model Note {
  id         String   @id @default(cuid())
  title      String
  content    String   @db.Text
  category   String?
  tags       String[] @default([])
  isFavorite Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId  String?
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
}

model Link {
  id          String   @id @default(cuid())
  url         String
  title       String?
  description String?  @db.Text
  imageUrl    String?
  category    String?
  tags        String[] @default([])
  isFavorite  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
}

model Image {
  id               String   @id @default(cuid())
  title            String?
  description      String?  @db.Text
  cloudStoragePath String
  isPublic         Boolean  @default(false)
  category         String?
  tags             String[] @default([])
  isFavorite       Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId        String?
  project          Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  role      String // user, assistant
  content   String   @db.Text
  context   String?  @db.Text // context about what project/idea was being discussed
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ── Sprint B: War Room persistence ──
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  agentId   String?
  agentName String?

  @@index([userId])
  @@index([projectId, createdAt])
}

// =============================================================================
// V4 MODELS — Vex&Co Lab Strategic PM Lab
// =============================================================================

// V4 enum: Project track type
enum TrackType {
  GO_TO_MARKET
  ONE_TIME_SERVICE
}

// Project archetype — distinguishes client projects from campaign projects
enum ProjectArchetype {
  CLIENT
  CAMPAIGN
}

// Prospect lifecycle status (separate from pipeline stage)
enum ProspectStatus {
  ACTIVE
  DORMANT
  LOST
  WON
}

// Prospect acquisition source
enum ProspectSource {
  MANUAL
  REFERRAL
  INBOUND
  OUTBOUND
  EVENT
  CHANNEL
  APOLLO
  LINKEDIN
  CORPUS
}

// Corpus document classification
enum CorpusDocumentType {
  CASE_STUDY
  PROPOSAL_WON
  PROPOSAL_LOST
  PROPOSAL_DORMANT
  INDUSTRY_RESEARCH
  METHODOLOGY
  UNCLASSIFIED
}

// Corpus document outcome
enum CorpusOutcome {
  WON
  LOST
  DORMANT
  IN_PROGRESS
  NA
}

// Embedding processing status
enum EmbeddingStatus {
  PENDING
  READY
  FAILED
}

// Outcome enum for DecisionLog
enum DecisionOutcome {
  APPROVED
  REJECTED
  DEFERRED
}

// AgileTask — Kanban board tasks per project
model AgileTask {
  id          String    @id @default(cuid())
  title       String
  description String?   @db.Text
  status      String    @default("backlog") // backlog, in-progress, review, done
  priority    String    @default("medium") // low, medium, high
  type        String    @default("task") // task, bug, feature, epic
  sprint      String?
  storyPoints Int?
  dueDate     DateTime?
  completedAt DateTime?
  labels      String[]  @default([])
  blockedBy   String[]  @default([])
  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assigneeId  String?
  assignee    User?     @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([assigneeId])
  @@index([projectId, status])
  @@index([sprint])
}

// InboxItem — Capture inbox (Raindrop, Jina, manual)
model InboxItem {
  id          String          @id @default(cuid())
  type        String // url, text, document, image
  rawContent  String          @db.Text
  sourceUrl   String?
  sourceTitle String?
  raindropId  String?         // ID único del bookmark en Raindrop
  status      String          @default("unprocessed") // unprocessed, processing, processed, archived
  priority    String          @default("medium")
  tags        String[]        @default([])
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  analysis    AnalysisResult?
  projectId   String?
  project     Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([userId, raindropId])
  @@index([userId])
  @@index([status])
  @@index([projectId])
}

// AnalysisResult — AI analysis output for InboxItems
model AnalysisResult {
  id               String    @id @default(cuid())
  inboxItemId      String    @unique
  inboxItem        InboxItem @relation(fields: [inboxItemId], references: [id], onDelete: Cascade)
  summary          String    @db.Text
  keyInsights      String[]  @default([])
  suggestedTags    String[]  @default([])
  category         String?
  sentiment        String?
  relevanceScore   Float?
  rawAiResponse    String?   @db.Text
  modelUsed        String?
  processingTimeMs Int?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// Sprint Inbox Intelligence — Correcciones acumuladas
// Feed few-shot calibration al Stage A classifier.
// Denormalizado: sobrevive al borrado del InboxItem fuente.
model InboxCorrection {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemTitle   String
  itemSummary String   @db.Text
  itemTags    String[] @default([])
  oldCategory String
  newCategory String
  createdAt   DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
}

// KnowledgeBase — Curated content/knowledge management
model KnowledgeBase {
  id           String    @id @default(cuid())
  title        String
  content      String    @db.Text
  contentType  String    @default("article") // article, snippet, template, reference
  category     String?
  tags         String[]  @default([])
  sourceUrl    String?
  isPublic     Boolean   @default(false)
  authorId     String
  author       User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  viewCount    Int       @default(0)
  lastViewedAt DateTime?
  route        String?
  status       String    @default("draft") // draft, published, archived
  summary      String?   @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([authorId])
  @@index([category])
  @@index([status])
}

// RoadmapTimeline — Visual roadmap phases per project
model RoadmapTimeline {
  id          String    @id @default(cuid())
  title       String
  description String?   @db.Text
  phase       String // discovery, build, launch, growth
  year        Int
  status      String    @default("planned") // planned, active, completed, blocked
  startDate   DateTime?
  endDate     DateTime?
  milestones  Json? // JSON array of milestone objects
  color       String?
  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  ownerId     String
  owner       User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([projectId])
  @@index([year, phase])
}

// AutomationLog — Cron job / automation audit trail
model AutomationLog {
  id             String    @id @default(cuid())
  jobName        String
  status         String // running, completed, failed
  itemsProcessed Int       @default(0)
  itemsFailed    Int       @default(0)
  errorMessage   String?   @db.Text
  metadata       Json?
  durationMs     Int?
  triggeredBy    String? // manual, cron, webhook
  userId         String?
  user           User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  startedAt      DateTime  @default(now())
  completedAt    DateTime?

  @@index([userId])
  @@index([jobName])
  @@index([status])
}

// UserPreferences — Per-user settings and integrations
model UserPreferences {
  id                   String    @id @default(cuid())
  userId               String    @unique
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  raindropToken        String?   @db.Text
  raindropLastSync     DateTime?
  jinaApiKey           String?   @db.Text
  defaultInboxView     String    @default("list") // list, grid, kanban
  aiAnalysisEnabled    Boolean   @default(true)
  autoTagging          Boolean   @default(true)
  emailDigestEnabled   Boolean   @default(false)
  emailDigestFrequency String    @default("weekly") // daily, weekly, never
  theme                String    @default("light") // light, dark, system
  timezone             String    @default("UTC")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

// DecisionLog — Human-in-the-Loop decision memory (prevents agent repetition)
model DecisionLog {
  id          String          @id @default(cuid())
  projectId   String
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  decision    String          @db.Text
  context     String          @db.Text
  outcome     DecisionOutcome
  agentSource String // Which agent generated this (strategist, revenue, etc.)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([projectId])
  @@index([userId])
  @@index([agentSource])
  @@index([outcome])
}

// WarRoomSession — Persistent War Room sessions (Sprint 4)
model WarRoomSession {
  id             String   @id @default(cuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  phase          String   @default("idle")
  currentAgentId String?
  supervisorPlan Json?
  agentResult    Json?
  history        Json     @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([projectId])
  @@index([userId])
}

// DriveDocSummary — Per-document AI summary from Drive folder scan
model DriveDocSummary {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  driveFileId String   // Google Drive file ID
  fileName    String
  fileType    String   // "document", "image", "spreadsheet", "code", "pdf"
  summary     String   @db.Text
  keyInsights String[] @default([])
  category           String?  // auto-classified: "strategy", "technical", "financial", "design", "research"
  wordCount          Int?     // approximate word count of source doc
  assetRole          String?  // logo | brand_asset | mockup | screenshot | reference | content | data | technical_spec | other
  visualDescription  String?  @db.Text
  unlinkedAt         DateTime?    // soft-delete: huérfanos auto + desvinculados manuales
  language                    String?  // "es" | "en" | "pt" | otro código ISO o null
  hasStructuredData           Boolean  @default(false)  // true si contiene tablas/código/JSON significativo
  processingError             String?  @db.Text  // mensaje de error si Stage A o B falló, null si OK
  lastNarrativeProcessedAt    DateTime?  // timestamp de última ejecución exitosa del pipeline narrativo
  createdAt          DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([projectId, driveFileId])
  @@index([projectId])
  @@index([category])
  @@index([unlinkedAt])
}

// =============================================================================
// DOCUMENT GENERATION + LEARNING SYSTEM
// =============================================================================

model StyleVariant {
  id               String   @id @default(cuid())
  name             String
  description      String?
  isDefault        Boolean  @default(false)
  cssOverrides     Json
  designPrinciples String?
  source           String   @default("manual")
  sourceItemIds    Json?
  usageCount       Int      @default(0)
  totalRating      Int      @default(0)
  ratingCount      Int      @default(0)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  documents DocumentGeneration[]
}

model DocumentGeneration {
  id              String        @id @default(cuid())
  projectId       String?
  project         Project?      @relation(fields: [projectId], references: [id])
  title           String
  format          String
  documentType    String        @default("report")
  styleVariantId  String?
  styleVariant    StyleVariant? @relation(fields: [styleVariantId], references: [id])
  sectionCount    Int
  feedbackRating  Int?
  feedbackComment String?
  feedbackAt      DateTime?
  generatedBy     String?
  createdAt       DateTime      @default(now())

  @@index([projectId])
  @@index([styleVariantId])
}

// =============================================================================
// FIRM INSIGHT — Cross-project institutional knowledge
// Vex&Co learns from itself: findings, validated segments,
// decisions, errors, contrarian patterns
// =============================================================================

model FirmInsight {
  id              String    @id @default(cuid())
  title           String
  content         String    @db.Text
  insightType     String    // "finding" | "segment" | "decision" | "error" | "pattern" | "contrarian_moat" | "framework_adopted"
  framework       Framework?
  functionalDomain      String?   // free-form: "senior_professionals", "fractional", "pricing_validation", etc. NOT sectoral.
  naicsSector           String?   // 2-digit NAICS code. Sectoral classification.
  naicsSectorConfidence Float?
  naicsSectorReviewed   Boolean   @default(false)
  naicsSectorReasoning  String?   @db.Text  // Razonamiento del classifier (incluye prefix de subject: [EXTERNAL_CLIENT], [VEXCO_OPERATING], [HORIZONTAL_OFFER], [METHODOLOGICAL])
  tags            String[]  @default([])
  confidence      Int       @default(50) // 0-100, grows with validation
  sourceProjectId String?
  sourceProject   Project?  @relation("InsightSource", fields: [sourceProjectId], references: [id], onDelete: SetNull)
  sourceAgentId   String?   // Which agent generated this insight
  validatedByUser Boolean   @default(false)
  isActive        Boolean   @default(true)
  metadata        Json?     // Flexible: can store analogVariable details, revenue data, etc.
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  ownerId         String
  owner           User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([insightType])
  @@index([tags])
  @@index([sourceProjectId])
  @@index([ownerId])
  @@index([functionalDomain])
  @@index([naicsSector])
}

// =============================================================================
// SPRINT M — CROSS-PORTFOLIO INTELLIGENCE
// =============================================================================

model Channel {
  id                String           @id @default(cuid())
  name              String
  type              String           // individual | firm | community | platform
  reachDescription  String?          @db.Text
  relationshipStage String           @default("cold") // cold | warm | activated | producing
  notes             String?          @db.Text
  ownerId           String
  owner             User             @relation(fields: [ownerId], references: [id])
  channelProjects   ChannelProject[]
  prospects         Prospect[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([ownerId])
}

model ChannelProject {
  id               String    @id @default(cuid())
  channelId        String
  projectId        String
  fitRationale     String?   @db.Text
  activationStatus String    @default("idle") // idle | proposed | active | producing
  lastTouchAt      DateTime?
  channel          Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  project          Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt        DateTime  @default(now())

  @@unique([channelId, projectId])
  @@index([channelId])
  @@index([projectId])
}

model Prospect {
  id                 String         @id @default(cuid())
  name               String
  company            String?
  source             ProspectSource @default(MANUAL)
  stage              String         @default("discovery") // discovery | qualified | proposal | negotiation | won | lost
  status             ProspectStatus @default(ACTIVE)
  estimatedDealValue Float?
  currency           String         @default("EUR")
  notes              String?        @db.Text
  lostReason         String?        @db.Text
  dormantSince       DateTime?
  ownerId            String
  owner              User           @relation(fields: [ownerId], references: [id])
  fits               ProspectFit[]
  channelId          String?
  channel            Channel?       @relation(fields: [channelId], references: [id])
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([ownerId])
  @@index([channelId])
  @@index([status])
}

model ProspectFit {
  id         String   @id @default(cuid())
  prospectId String
  projectId  String
  fitScore   Int      // 0-100
  rationale  String   @db.Text
  isPrimary  Boolean  @default(false)
  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([prospectId, projectId])
  @@index([prospectId])
  @@index([projectId])
}

model MetaProject {
  id               String                 @id @default(cuid())
  name             String
  narrative        String                 @db.Text
  status           String                 @default("active") // active | paused | dissolved
  affinitySnapshot Json                   // snapshot de scores al momento de instanciación
  ownerId          String
  owner            User                   @relation(fields: [ownerId], references: [id])
  components       MetaProjectComponent[]
  milestones       MetaProjectMilestone[]
  revenueScore     Float?                 // score propio en Revenue Priority
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@index([ownerId])
}

model MetaProjectComponent {
  id            String      @id @default(cuid())
  metaProjectId String
  projectId     String
  role          String      @default("complement") // anchor | complement | enabler
  metaProject   MetaProject @relation(fields: [metaProjectId], references: [id], onDelete: Cascade)
  project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  addedAt       DateTime    @default(now())

  @@unique([metaProjectId, projectId])
  @@index([metaProjectId])
  @@index([projectId])
}

model MetaProjectMilestone {
  id                  String      @id @default(cuid())
  metaProjectId       String
  title               String
  description         String?     @db.Text
  status              String      @default("pending") // pending | in_progress | done | blocked
  dependsOnProjectIds String[]
  dueDate             DateTime?
  ownerId             String?
  metaProject         MetaProject @relation(fields: [metaProjectId], references: [id], onDelete: Cascade)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@index([metaProjectId])
}

model CrossPortfolioAnalysis {
  id                   String    @id @default(cuid())
  status               String    @default("running") // running | completed | failed
  agentVersion         String
  affinityMatrix       Json      // [{ projectAId, projectBId, audience, valueProp, channels, deliverables, overall, rationale }]
  metaProjectProposals Json      // [{ name, narrative, componentProjectIds, suggestedMilestones, rationale, clusterAvgScore }]
  channelRouting       Json      // [{ channelId, recommendedProjectIds, rationale, nextAction }]
  prospectRouting      Json      // [{ prospectId, fits: [{ projectId, fitScore, rationale }], primaryProjectId, nextAction }]
  triggeredBy          String
  errorMessage         String?   @db.Text
  createdAt            DateTime  @default(now())
  completedAt          DateTime?
}

model RevenuePriorityEntry {
  id           String   @id @default(cuid())
  entityType   String   // project | metaProject
  entityId     String
  score        Float
  calculatedAt DateTime @default(now())
  rationale    String?  @db.Text

  @@unique([entityType, entityId])
  @@index([entityType])
}

// =============================================================================
// SPRINT M.2a — FIRM CORPUS (Transversal Case-Book)
// =============================================================================

model FirmCorpus {
  id          String           @id @default(cuid())
  name        String           @default("Vex&Co Firm Corpus")
  description String?          @db.Text
  singleton   Boolean          @default(true) @unique
  documents   CorpusDocument[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model CorpusDocument {
  id               String             @id @default(cuid())
  corpusId         String
  corpus           FirmCorpus         @relation(fields: [corpusId], references: [id], onDelete: Cascade)
  driveFileId      String             @unique
  driveFileName    String
  driveFileUrl     String
  mimeType         String
  documentType     CorpusDocumentType @default(UNCLASSIFIED)
  industry         String?
  geography        String?
  companySize      String?
  outcome          CorpusOutcome?
  provenance       Provenance         @default(UNKNOWN)
  archived         Boolean            @default(false)
  reviewedAt       DateTime?
  reviewedBy       String?
  customTags       String[]           @default([])
  extractedSummary String?            @db.Text
  keyEntities      Json?              // [{ name, type: COMPANY|PERSON|PRODUCT|FRAMEWORK|CONCEPT|LOCATION }]
  rawContent       String?            @db.Text
  embeddingStatus  EmbeddingStatus    @default(PENDING)
  lastProcessedAt  DateTime?
  processingError  String?            @db.Text
  frameworkSources FrameworkSourceDocument[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([corpusId])
  @@index([documentType])
  @@index([industry])
  @@index([corpusId, documentType, industry])
  @@index([archived])
}

// =============================================================================
// SPRINT M.2a-PLUS — FRAMEWORKS + OPERATIONAL SOURCES
// =============================================================================

enum Provenance {
  OWN        // Material producido por Vex&Co
  EXTERNAL   // Material de terceros curado como referencia
  MIXED      // Hibrido (propuesta Vex&Co que cita frameworks externos)
  UNKNOWN    // No determinable
}

enum FrameworkLifecycleStage {
  EXTERNAL   // Tal cual del autor original
  ADOPTED    // Vex&Co lo usa sistematicamente, atribuido
  ADAPTED    // Modificado, atribucion parcial
  DERIVED    // Nuevo framework propio inspirado en X
  OWN        // Framework propio puro
}

enum FrameworkUpdateStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum FrameworkStatus {
  ACTIVE
  DEPRECATED
}

enum OperationalSourceKind {
  PARTNER_LIST
  CONTACT_LIST
  COMPANY_LIST
  CAMPAIGN_DATA
  UNKNOWN_TABULAR
}

enum OperationalTargetSystem {
  HUBSPOT
  APOLLO
  NOTION
  UNDECIDED
}

enum OperationalSourceStatus {
  PENDING    // Detectado, no revisado
  TAGGED     // Diego asigno targetSystem
  MIGRATED   // Ya cargado en destino
  ARCHIVED   // Diego decidio no usarlo
}

model Framework {
  id                    String                   @id @default(cuid())
  name                  String
  slug                  String                   @unique
  originSource          String                   // e.g. "Winning by Design", "Reforge", "Vex&Co Original"
  originAuthor          String?
  originYear            Int?
  lifecycleStage        FrameworkLifecycleStage   @default(EXTERNAL)
  originalDescription   String                   @db.Text
  originalComponents    Json?                    // array of stages/elements
  currentVexcoVariant   String?                  @db.Text
  currentVexcoComponents Json?
  adaptationLog         Json                     @default("[]") // [{date, projectId, modification, sessionId}]
  applicationCount      Int                      @default(0)
  lastAppliedAt         DateTime?
  lastDiscoveryCheck    DateTime?
  firmInsightId         String?                  @unique
  firmInsight           FirmInsight?             @relation(fields: [firmInsightId], references: [id])
  sourceDocuments       FrameworkSourceDocument[]
  appliedInProjects     FrameworkProject[]
  updates               FrameworkUpdate[]
  derivedFromId         String?
  derivedFrom           Framework?               @relation("FrameworkDerivation", fields: [derivedFromId], references: [id])
  derivatives           Framework[]              @relation("FrameworkDerivation")
  status                FrameworkStatus           @default(ACTIVE)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([lifecycleStage])
  @@index([originSource])
}

model FrameworkSourceDocument {
  id          String         @id @default(cuid())
  frameworkId String
  framework   Framework      @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  documentId  String
  document    CorpusDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  confidence  Float          // 0..1
  detectedAt  DateTime       @default(now())

  @@unique([frameworkId, documentId])
  @@index([frameworkId])
  @@index([documentId])
}

model FrameworkProject {
  id          String    @id @default(cuid())
  frameworkId String
  framework   Framework @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  appliedAt   DateTime  @default(now())
  notes       String?   @db.Text

  @@unique([frameworkId, projectId])
  @@index([frameworkId])
  @@index([projectId])
}

model FrameworkUpdate {
  id          String                @id @default(cuid())
  frameworkId String
  framework   Framework             @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  source      String                // URL, "raindrop", "perplexity_discovery", "manual"
  description String                @db.Text
  rawPayload  Json?
  foundAt     DateTime              @default(now())
  status      FrameworkUpdateStatus @default(PENDING)
  reviewedAt  DateTime?

  @@index([frameworkId])
  @@index([status])
}

model OperationalSource {
  id               String                   @id @default(cuid())
  driveFileId      String                   @unique
  driveFileName    String
  driveFileMimeType String
  driveFolderId    String?
  detectedKind     OperationalSourceKind    @default(UNKNOWN_TABULAR)
  targetSystem     OperationalTargetSystem?
  status           OperationalSourceStatus  @default(PENDING)
  notes            String?                  @db.Text
  discoveredAt     DateTime                 @default(now())
  lastSeenAt       DateTime                 @default(now())

  @@index([detectedKind])
  @@index([status])
}

// =============================================================================
// CORPUS REPROCESS JOB — Background job state for cron-based reprocessing
// =============================================================================

enum ReprocessJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model CorpusReprocessJob {
  id             String             @id @default(cuid())
  status         ReprocessJobStatus @default(PENDING)
  cursor         String?
  totalProcessed Int                @default(0)
  totalFailed    Int                @default(0)
  totalBatches   Int                @default(0)
  errors         Json               @default("[]")
  startedAt      DateTime           @default(now())
  lastTickAt     DateTime?
  completedAt    DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([status])
}

// =============================================================================
// MARKET INTELLIGENCE PIPELINE (MIP) — Sub-entrega 1A
// =============================================================================

enum MarketBriefType {
  COMMERCIAL_RADAR
  CONSULTING_MARKET
  INTERNATIONALIZATION
  PRICING_BENCHMARK
  REGULATORY_ALERT
}

enum ProjectQueryType {
  COMPETITIVE_LANDSCAPE
  TAM_SAM_SOM
  PRICING_REFERENCE
  REGULATORY_CONTEXT
  CUSTOM
}

model MarketIntelligenceTemplate {
  id             String          @id @default(cuid())
  name           String
  briefType      MarketBriefType
  schedule       String
  sectorTags     String[]
  geographyTags  String[]
  systemPrompt   String          @db.Text
  userPrompt     String          @db.Text
  responseSchema Json
  isActive       Boolean         @default(true)
  lastRunAt      DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  briefs         MarketIntelligenceBrief[]

  @@index([isActive])
}

model MarketIntelligenceBrief {
  id             String          @id @default(cuid())
  templateId     String
  template       MarketIntelligenceTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  briefType      MarketBriefType
  publishedAt    DateTime        @default(now())
  structuredData Json
  rawNarrative   String?         @db.Text
  sectorTags     String[]
  geographyTags  String[]
  tokenCost      Int?
  createdAt      DateTime        @default(now())

  @@index([templateId, publishedAt])
  @@index([briefType, publishedAt])
}
